# ======================================================================
# Nova / OpenClaw Discord Channel — environment variables
# Copy to `.env` and fill in values. Never commit `.env`.
# ======================================================================

# --- Discord bot ------------------------------------------------------
# From https://discord.com/developers/applications -> Bot -> Reset Token
DISCORD_BOT_TOKEN=your-bot-token-here

# Optional: restrict slash-command syncing to one guild during development.
# Leave blank to sync globally (can take up to 1 hour to propagate).
DISCORD_DEV_GUILD_ID=

# Comma-separated list of user IDs that are considered bot owners.
# Owners have access to admin-only slash commands (/admin sync, reload, ...).
DISCORD_OWNER_IDS=

# --- OpenClaw channel identity ---------------------------------------
# These are consumed by the OpenClaw gateway when it loads this bot as a
# "Discord channel". They control session keying and access policies.
# See docs: https://docs.openclaw.ai/channels/discord
OPENCLAW_AGENT_ID=main
OPENCLAW_DM_POLICY=pairing              # pairing | allowlist | open | disabled
OPENCLAW_GROUP_POLICY=allowlist         # open | allowlist | disabled
OPENCLAW_ALLOW_FROM=                    # CSV of user IDs, or "*" for open
OPENCLAW_HISTORY_LIMIT=20
OPENCLAW_REPLY_MODE=batched             # off | first | all | batched
OPENCLAW_STREAMING=off                  # off | partial | block | progress

# --- Runtime ----------------------------------------------------------
LOG_LEVEL=INFO
COMMAND_PREFIX=!
ENVIRONMENT=development                 # development | production

# Optional outbound proxy for the gateway websocket.
# Example: http://proxy.example.com:8080
HTTPS_PROXY=

# --- Music cog --------------------------------------------------------
# Path to ffmpeg executable. On most systems `ffmpeg` on $PATH is fine.
FFMPEG_PATH=ffmpeg
# Max queue length per guild.
MUSIC_MAX_QUEUE=100
